# Local dev: use a local SQLite file
DATABASE_URL="file:local.db"
DATABASE_AUTH_TOKEN=""

# Production (Turso cloud):
# DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# SvelteKit origin — your Vercel URL in production
ORIGIN="http://localhost:5173"

# Better Auth secret — use a random 32-char string in production
BETTER_AUTH_SECRET="change-me-to-32-random-chars"
